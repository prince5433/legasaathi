# ── Mode ───────────────────────────────────────
# DEV_MODE=true bypasses Clerk auth (returns user_id="dev_user_001").
# Set to false in production to enforce Clerk JWT verification.
DEV_MODE=true
FRONTEND_URL=http://localhost:3000
PORT=8000

# ── LLM Providers ──────────────────────────────
# OpenAI is primary; Gemini is fallback when OpenAI call fails.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

GOOGLE_AI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_CHAT_MODEL=gemini-1.5-flash

# ── LangSmith (optional — 3 vars enable auto-trace) ──
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=legalsaathi

# ── MongoDB ───────────────────────────────────
MONGODB_URI=mongodb://admin:admin@localhost:27017
MONGODB_DB=legalsaathi

# ── Qdrant ────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=legal_docs

# ── Neo4j ─────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-to-match-docker-compose

# ── AWS S3 (optional — falls back to local file:// if unset) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name

# ── Clerk (required when DEV_MODE=false) ──
CLERK_SECRET_KEY=<paste-your-clerk-secret-key-here>
# Paste the JWT public key on one line with \n for newlines, or wrap in double quotes.
CLERK_PEM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----

# ── Deadline Notifier ─────────────────────────
ENABLE_DEADLINE_NOTIFIER=true
NOTIFIER_INTERVAL_HOURS=6
NOTIFIER_LOOKAHEAD_DAYS=30
# Used as the recipient when DEV_MODE=true and Clerk lookup is unavailable.
DEV_EMAIL=

# ── SMTP (leave SMTP_HOST blank to disable email — deadlines still tracked in DB) ──
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=LegalSaathi <noreply@legalsaathi.local>
SMTP_USE_TLS=true
