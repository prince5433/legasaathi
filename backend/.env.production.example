# ============================================================
# LegalSaathi Backend — Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.production.example .env
# ============================================================

# ===== MODE =====
DEV_MODE=false
FRONTEND_URL=https://legalsaathi.yourdomain.com
PORT=8000

# ===== LLM API Keys =====
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

GOOGLE_AI_API_KEY=your-google-ai-key-here
GEMINI_CHAT_MODEL=gemini-1.5-flash

# ===== LangChain Tracing (Optional) =====
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=legalsaathi

# ===== Databases =====
# NOTE: Docker Compose mein service names use karo (mongodb, qdrant, neo4j)
#       Standalone mein localhost use karo
MONGODB_URI=mongodb://admin:StrongMongoPass123!@mongodb:27017
MONGODB_DB=legalsaathi

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=legal_docs

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=StrongNeo4jPass123!

# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=legalsaathi-docs

# ===== Clerk Authentication =====
CLERK_SECRET_KEY=sk_live_your-clerk-secret
CLERK_PEM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----

# ===== Deadline Notifier =====
ENABLE_DEADLINE_NOTIFIER=true
NOTIFIER_INTERVAL_HOURS=6
NOTIFIER_LOOKAHEAD_DAYS=30

# ===== SMTP (Email) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=LegalSaathi <noreply@legalsaathi.com>
SMTP_USE_TLS=true
